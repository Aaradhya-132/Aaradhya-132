# --- explorer.ai MASTER CONFIGURATION ---

# 1. Database Connectivity (Strictly Required)
# Example: mongodb+srv://<user>:<password>@cluster.mongodb.net/explorer_ai
MONGO_URI=your_mongodb_connection_string_here

# 2. Security Protocols
# A random cryptographic string for session integrity
SESSION_SECRET=your_hyper_secure_session_secret_here

# 3. Server Node Operations
PORT=5000
NODE_ENV=development

# 4. Neural Intelligence (Optional but recommended for AI features)
# Obtain from Google AI Studio: https://aistudio.google.com/
# GEMINI_API_KEY=your_gemini_api_key_here
